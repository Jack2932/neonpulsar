# Copy to deploy/neonchat.env and adjust values.
SECRET_KEY=change-me
PREFERRED_URL_SCHEME=https
SOCKETIO_ASYNC_MODE=gevent
# RTC / TURN (optional)
# RTC_TURN_URLS=turn:your.domain:3478?transport=udp
# RTC_TURN_USERNAME=neon
# RTC_TURN_CREDENTIAL=pass
# SSL for direct local run only (nginx usually terminates SSL)
# SSL_CERT=/etc/letsencrypt/live/example.com/fullchain.pem
# SSL_KEY=/etc/letsencrypt/live/example.com/privkey.pem

# Database (optional; sqlite remains default if omitted)
# DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/neonchat

# Cookies / runtime
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
LOG_LEVEL=INFO
SLOW_REQUEST_MS=2500

# Gunicorn
GUNICORN_BIND=127.0.0.1:5000
GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=25
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
# GUNICORN_WORKER_CLASS=eventlet
